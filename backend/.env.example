# ── Server ───────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── Persistent storage (production) ──────────────────────
# In production (Railway) point this at the mounted Volume so the SQLite DB
# AND uploaded images survive restarts/redeploys, e.g. DATA_DIR=/data
# Leave empty locally (uses backend/data + frontend/images/uploads).
DATA_DIR=

# ── Auth ─────────────────────────────────────────────────
JWT_SECRET=change_me_to_a_long_random_secret
# Token lifetime for the admin session cookie
JWT_EXPIRES_IN=7d

# ── Database ─────────────────────────────────────────────
# dialect: "sqlite" (default, zero-install) or "postgres"
DB_DIALECT=sqlite
# Used only when DB_DIALECT=postgres
DATABASE_URL=postgresql://user:pass@localhost:5432/mnl_dental

# ── Email (Nodemailer) ───────────────────────────────────
# Leave SMTP_* empty to use the dev Ethereal transport (prints a preview URL).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
# Address the clinic notifications are sent to
ADMIN_EMAIL=clinic@mnl-dental.bg
MAIL_FROM="Дентални клиники MNL <no-reply@mnl-dental.bg>"

# ── Default admin (seeded on first run) ──────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
